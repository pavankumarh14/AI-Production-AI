# Copy this file to .env and fill in your provider API keys.
# Never commit your real .env to source control.

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=

# Google Gemini (example name — use the key you received from Google Cloud)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# Grok / xAI (example)
GROK_API_KEY=
GROK_MODEL=

# Olama (example)
OLAMA_API_KEY=
OLAMA_MODEL=

# Optional: default provider to use when none is specified in requests
LLM_PROVIDER=gemini

# Optional: default model to use when none is specified per-provider
LLM_MODEL=

# Other optional settings
PORT=4174
NODE_ENV=development
